<Window x:Class="EvadedApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Evasion Tool" Height="450" Width="600"
        Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Local Network Evasion Controller" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,20">
            <CheckBox x:Name="chkTcpSni" Content="Enable TCP SNI Fragmentation (e.g. GitHub, Discord bypass)" IsChecked="True"/>
            <CheckBox x:Name="chkUdpSpoof" Content="Enable UDP Port 53 Spoofing (e.g. Game traffic bypass)" IsChecked="True"/>
            
            <TextBlock Text="Target Process Names (comma separated, leave empty for ALL traffic):" Margin="0,10,0,5" Foreground="#A0A0A0"/>
            <TextBox x:Name="txtProcessList" Text="discord.exe, leagueclient.exe, python.exe" Background="#2D2D30" Foreground="#E0E0E0" BorderThickness="1" BorderBrush="#555555" Padding="5"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Button x:Name="btnToggle" Content="Start Engine" Click="BtnToggle_Click" Width="120" Height="30"/>
                <TextBlock x:Name="txtStatus" Text="Status: Stopped" Margin="20,5,0,0" Foreground="#FF5252" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
        
        <GroupBox Grid.Row="2" Header="Logs" Foreground="#A0A0A0" BorderBrush="#333333">
            <ScrollViewer x:Name="logScroll" Margin="5">
                <TextBlock x:Name="txtLogs" TextWrapping="Wrap" Foreground="#00E676" FontFamily="Consolas" FontSize="12"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>
